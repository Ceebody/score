{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "users": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "role": {
          ".validate": "newData.isString() && (newData.val() === 'admin' || newData.val() === 'teacher' || newData.val() === 'student' || newData.val() === 'parent')"
        },
        "classId": {
          ".validate": "newData.isString() || newData.val() == null"
        },
        "studentId": {
          ".validate": "newData.isString() || newData.val() == null"
        }
      },
      ".indexOn": [
        "role"
      ]
    },
    "students": {
      ".read": "auth != null",
      ".indexOn": [
        "lastName",
        "class"
      ],
      "$classId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'teacher' && root.child('users').child(auth.uid).child('classId').val() === $classId))",
        "$studentKey": {
          ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'teacher' && root.child('users').child(auth.uid).child('classId').val() === $classId) || (data.exists() && data.child('uid').val() === auth.uid) || (root.child('users').child(auth.uid).child('role').val() === 'parent' && root.child('parents').child(auth.uid).child($studentKey).exists()))",
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'teacher' && root.child('users').child(auth.uid).child('classId').val() === $classId))",
          "uid": {
            ".validate": "newData.isString() || newData.val() == null"
          },
          "firstName": {
            ".validate": "newData.isString() || newData.val() == null"
          },
          "lastName": {
            ".validate": "newData.isString() || newData.val() == null"
          }
        }
      }
    },
    "attendance": {
      "$classId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'teacher' && root.child('users').child(auth.uid).child('classId').val() === $classId) || root.child('users').child(auth.uid).child('role').val() === 'student' || root.child('users').child(auth.uid).child('role').val() === 'parent')",
        "$date": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'teacher' && root.child('users').child(auth.uid).child('classId').val() === $classId))",
          "$studentId": {
            ".validate": "newData.hasChildren(['status'])",
            "status": {
              ".validate": "newData.val() === 'Present' || newData.val() === 'Absent' || newData.val() === 'Late' || newData.val() === 'Excused'"
            }
          }
        }
      }
    },
    "timetables": {
      "$classId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        "$day": {
          ".validate": "newData.hasChildren(['periods'])"
        }
      }
    },
    "scores": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')"
    },
    "notifications": {
      "$scope": {
        "$id": {
          ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || $scope === 'global' || ($scope === 'user' && $id === auth.uid) || ($scope === 'class' && root.child('users').child(auth.uid).child('classId').val() === $id))",
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      }
    },
    "fcmTokens": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "teachers": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "parents": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "classTeacherRecords": {
      "$classId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'teacher' && root.child('users').child(auth.uid).child('classId').val() === $classId))",
        "$studentUid": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'teacher' && root.child('users').child(auth.uid).child('classId').val() === $classId))"
        }
      }
    },
    "midtermScores": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')"
    },
    "reportsPublished": {
      "$classId": {
        "$termKey": {
          ".read": "auth != null",
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        }
      }
    },
    "midtermsPublished": {
      "$year": {
        "$termName": {
          "$classId": {
            ".read": "auth != null",
            ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
          }
        }
      }
    },
    "notificationReadsByUser": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "classes": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "terms": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "backups": {
      "$backupId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'teacher')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    }
  }
}